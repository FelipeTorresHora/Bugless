// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String        @id @default(ulid())
  name       String        @map("name_user")
  email      String        @unique @map("email_user")
  password   String        @map("password_user")
  createdAt  DateTime      @default(now()) @map("created_at")

  projects            Project[]
  apiKeys             ApiKey[]
  subscription        Subscription?
  usageMetrics        UsageMetric[]
  submissions         Submission[]
  cliSessions         CliSession[]
  githubInstallations GitHubInstallation[]
  webSessions         WebSession[]

  @@map("user")
}

model CliSession {
  id        String   @id @default(ulid())
  sessionId String   @unique @map("session_id")
  token     String?  @map("token")
  userId    String?  @map("user_id")
  status    String   @default("pending") // pending | completed | expired
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cli_session")
}

model Project {
  id          String       @id @default(ulid())
  name        String       @map("name_project")
  description String?
  userId      String       @map("id_user")
  repositoryUrl String? @map("repository_url")
  repositoryPath String? @map("repository_path")
  language      String? @map("language_project")
  customInstructions String? @map("custom_instructions")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime?    @map("updated_at")
  
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  submissions Submission[]
  
  @@map("project")
}

model Subscription {
  id                  String             @id @default(ulid())
  userId              String             @unique @map("id_user")
  plan                SubscriptionPlan   @default(FREE)
  status              SubscriptionStatus @default(ACTIVE)
  stripeCustomerId    String?            @unique @map("stripe_customer_id")
  stripeSubscriptionId String?           @unique @map("stripe_subscription_id")
  stripePriceId       String?            @map("stripe_price_id")
  currentPeriodStart  DateTime?          @map("current_period_start")
  currentPeriodEnd    DateTime?          @map("current_period_end")
  cancelAtPeriodEnd   Boolean            @default(false) @map("cancel_at_period_end")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  usageMetrics UsageMetric[]

  @@map("subscription")
}

model UsageMetric {
  id             String   @id @default(ulid())
  userId         String   @map("id_user")
  subscriptionId String   @map("id_subscription")
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  reviewsCount   Int      @default(0) @map("reviews_count")
  reviewsLimit   Int      @map("reviews_limit")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart])
  @@index([userId, periodStart])
  @@map("usage_metric")
}

model ApiKey {
  id              String     @id @default(ulid())
  userId          String     @map("id_user")
  provider        AiProvider @map("provider")
  encryptedKey    String     @map("encrypted_key")
  keyName         String?    @map("key_name")
  isActive        Boolean    @default(true) @map("is_active")
  isValid         Boolean    @default(true) @map("is_valid")
  lastValidatedAt DateTime?  @map("last_validated_at")
  lastUsedAt      DateTime?  @map("last_used_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@map("api_key")
}

enum AiProvider {
  GEMINI
  OPENAI
  CLAUDE
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum SubmissionModeEnum {
  PR_DIFF
  UNCOMMITTED
  COMMIT
  CUSTOM
}

enum StatusSubmissionEnum {
  PENDING
  COMPLETED
  FAILED
}

model StatusSubmission {
  id   String @id @default(ulid())
  name StatusSubmissionEnum @map("name_status_submission")
  
  submissions Submission[]
  
  @@map("status_submission")
}

model Submission {
  id                String            @id @default(ulid())
  codeContent       String            @map("code_content") @db.Text
  submissionMode    SubmissionModeEnum @map("submission_mode")
  aiProvider        AiProvider?       @map("ai_provider")
  usedUserKey       Boolean           @default(false) @map("used_user_key")
  createdAt         DateTime          @default(now()) @map("created_at")
  userId            String            @map("user_id")
  projectId         String            @map("project_id")
  statusSubmissionId String           @map("id_status_submission")
  metadata          Json?             @map("metadata")

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  statusSubmission  StatusSubmission  @relation(fields: [statusSubmissionId], references: [id])
  reviews           Review[]
  githubPullRequest GitHubPullRequest?

  @@map("submission")
}

model Review {
  id              String   @id @default(ulid())
  summary         String?  @db.Text
  detectedIssues  String?  @map("detected_issues") @db.Text
  suggestedChanges String? @map("suggested_changes") @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  submissionId    String   @map("id_submission")

  submission Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("review")
}

model GitHubInstallation {
  id             String   @id @default(ulid())
  installationId String   @unique @map("installation_id")
  accountLogin   String   @map("account_login")
  accountType    String   @map("account_type")
  userId         String?  @map("user_id")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  pullRequests GitHubPullRequest[]

  @@map("github_installations")
}

model GitHubPullRequest {
  id             String   @id @default(ulid())
  prNumber       Int      @map("pr_number")
  installationId String   @map("installation_id")
  owner          String
  repo           String
  headRef        String   @map("head_ref")
  baseRef        String   @map("base_ref")
  commitSha      String   @map("commit_sha")
  submissionId   String?  @unique @map("submission_id")
  checkRunId     String?  @map("check_run_id")
  status         String   @default("pending")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  installation GitHubInstallation @relation(fields: [installationId], references: [installationId])
  submission   Submission?        @relation(fields: [submissionId], references: [id])

  @@unique([owner, repo, prNumber])
  @@map("github_pull_requests")
}

model WebSession {
  id                String    @id @default(ulid())
  userId            String    @map("user_id")
  refreshTokenHash  String    @unique @map("refresh_token_hash")
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedBySessionId String? @map("replaced_by_session_id")
  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("web_session")
}
